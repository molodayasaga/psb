---
- name: Установка и запуск chkrootkit
  hosts: test
  become: yes
  gather_facts: yes

  tasks:
    - name: Установка chkrootkit
      apt:
        name: chkrootkit
        state: present
        update_cache: yes

    - name: Запуск проверки
      command: chkrootkit
      register: chkrootkit_result
      ignore_errors: yes

    - name: Сохранение результата
      copy:
        content: |
          Результат проверки chkrootkit
          ==============================
          {{ chkrootkit_result.stdout }}
          {{ chkrootkit_result.stderr }}
        dest: "/home/tserg/ansible_laba01/laba04/chkrootkit_result.txt"
      delegate_to: localhost
      run_once: true
